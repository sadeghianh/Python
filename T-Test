        "# ##############################################################################\n",
        "# CELL 6 — Helper Functions\n",
        "# ##############################################################################\n",
        "\n",
        "def confidence_interval_1sample(data, confidence=0.95):\n",
        "    \"\"\"95% CI for a one-sample mean.\"\"\"\n",
        "    n, m, s = len(data), np.mean(data), np.std(data, ddof=1)\n",
        "    t_crit = stats.t.ppf((1 + confidence) / 2, df=n - 1)\n",
        "    margin = t_crit * s / np.sqrt(n)\n",
        "    return round(m - margin, 4), round(m + margin, 4)\n",
        "\n",
        "def confidence_interval_2sample(g1, g2, confidence=0.95):\n",
        "    \"\"\"95% CI for the difference of two independent means (pooled).\"\"\"\n",
        "    n1, n2 = len(g1), len(g2)\n",
        "    m1, m2 = np.mean(g1), np.mean(g2)\n",
        "    s1, s2 = np.std(g1, ddof=1), np.std(g2, ddof=1)\n",
        "    sp2    = ((n1-1)*s1**2 + (n2-1)*s2**2) / (n1+n2-2)\n",
        "    t_crit = stats.t.ppf((1 + confidence) / 2, df=n1+n2-2)\n",
        "    margin = t_crit * np.sqrt(sp2 * (1/n1 + 1/n2))\n",
        "    diff   = m1 - m2\n",
        "    return round(diff - margin, 4), round(diff + margin, 4)\n",
        "\n",
        "def confidence_interval_paired(diff, confidence=0.95):\n",
        "    \"\"\"95% CI for the mean of paired differences.\"\"\"\n",
        "    n, m, s = len(diff), np.mean(diff), np.std(diff, ddof=1)\n",
        "    t_crit  = stats.t.ppf((1 + confidence) / 2, df=n - 1)\n",
        "    margin  = t_crit * s / np.sqrt(n)\n",
        "    return round(m - margin, 4), round(m + margin, 4)\n",
        "\n",
        "def decision(p_value, alpha=0.05):\n",
        "    return \"Reject H₀\" if p_value < alpha else \"Fail to Reject H₀\"\n",
        "\n",
        "def fmt_p(p):\n",
        "    return \"< 0.0001\" if p < 0.0001 else f\"{p:.4f}\"\n",
        "\n",
        "print(\"✅ Helper functions ready.\")\n",
        "\n"
